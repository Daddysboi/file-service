# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017/file-service

# Redis Configuration (optional)
# REDIS_URL=redis://localhost:6379
 CLIENT_URL=http://localhost:3000


# Local Storage Configuration (optional)
# LOCAL_STORAGE_PATH=./uploads

# File Service Configuration
MAX_FILE_SIZE=50 # Maximum file size in MB
DEFAULT_STORAGE_TYPE=gridfs # 'gridfs', 's3', or 'local'

# Image Processing Configuration
IMAGE_OPTIMIZATION_ENABLED=true
DEFAULT_IMAGE_QUALITY=80
MAX_IMAGE_DIMENSION=4000
GENERATE_THUMBNAILS=true

# Caching Configuration
CACHING_ENABLED=true
CACHE_MAX_SIZE=100 # Maximum cache size in MB
CACHE_TTL=3600 # Cache TTL in seconds

# Security Configuration
CORS_ORIGINS=* # Comma-separated list of allowed origins
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=1d
SERVICE_API_KEY=your_service_api_key

# Rate Limiting Configuration
GLOBAL_RATE_LIMIT=500
GLOBAL_RATE_LIMIT_WINDOW=300 # Window in seconds
UPLOAD_RATE_LIMIT=20
UPLOAD_RATE_LIMIT_WINDOW=60 # Window in seconds

# Monitoring Configuration
ENABLE_METRICS=false

# Clustering Configuration
ENABLE_CLUSTERING=false
# WORKER_COUNT=0 # 0 means use CPU count